# Docker (include trailing slash if set)
# DOCKER_PROXY=docker.company.local/docker/

# Proxy settings for Nextcloud App Store and external services (uncomment if needed)
# HTTP_PROXY=http://proxy.company.local:3128
# HTTPS_PROXY=http://proxy.company.local:3128
# NO_PROXY=localhost,127.0.0.1

# Database
MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_PASSWORD=your_secure_password

# Nextcloud
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=your_admin_password
NEXTCLOUD_TRUSTED_DOMAINS=localhost

# External S3 Storage (uncomment to use MinIO at s3.company.local)
# S3_ACCESS_KEY=your_s3_access_key
# S3_SECRET_KEY=your_s3_secret_key

# OnlyOffice
ONLYOFFICE_JWT_SECRET=your_onlyoffice_jwt_secret
